#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

readonly secrets=(
  NIKS3_API_TOKEN
  NIKS3_CACHE_URL
  NIKS3_DB
  NIKS3_S3_ACCESS_KEY
  NIKS3_S3_ENDPOINT
  NIKS3_S3_SECRET_KEY
  NIKS3_SIGN_KEY
)

for secret in "${secrets[@]}"; do
  if [[ -z "${!secret:-}" ]]; then
    printf 'Missing required SecretSpec value: %s\n' "$secret" >&2
    exit 1
  fi

  printf '%s' "${!secret}" | wrangler secret put "$secret" --config wrangler.toml
done
